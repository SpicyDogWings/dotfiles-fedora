{
  "vim_mode": false,
  "cli_default_open_behavior": "existing_window",
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {
        "database_url": "postgresql://postgres:root@localhost:5432/siciun"
      }
    }
  },
  "terminal": {
    "font_size": 14.0
  },
  "diff_view_style": "unified",
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "codestral"
  },
  "agent_servers": {
    "mistral-vibe": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "relative_line_numbers": "enabled",
  "agent": {
    "profiles": {
      "master": {
        "default_model": {
          "provider": "mistral",
          "model": "mistral-medium-latest",
          "enable_thinking": false
        },
        "name": "Master",
        "tools": {
          "search_web": true,
          "update_plan": true,
          "skill": true,
          "rename_symbol": false,
          "read_file": true,
          "list_directory": true,
          "grep": true,
          "get_code_actions": false,
          "find_references": true,
          "find_path": true,
          "fetch": true
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "postgres-context-server": {
            "tools": {
              "query": true,
              "pg-schema": true
            }
          }
        }
      }
    },
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Warm Charmed Icons",
    "dark": "Warm Charmed Icons"
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Retro 001"
  },
  "title_bar": {
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": true,
  },
  "tab_bar": {
    "show": true,
  },
  "toolbar": {
    "quick_actions": true,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": true,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "always",
    },
    "indent_guides": {
      "show": "always",
    },
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 300,
    "indent_guides": {
      "show": "always",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "scrollbar": {
    "show": "always",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true,
    "runnables": true,
  },
  "indent_guides": {
    "enabled": true,
  },
  "ui_font_family": "CommitMono Nerd Font",
  "ui_font_size": 14.0,
  "buffer_font_family": "CommitMono Nerd Font",
  "buffer_font_size": 14.0,
  "buffer_line_height": {
    "custom": 2,
  },
  "agent_buffer_font_size": 14.0,
  "helix_mode": true,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "underline",
  "cursor_blink": true,
  "selection_highlight": true,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "always",
  "current_line_highlight": "all",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": false,
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "inline_code_actions": true,
  "lsp_document_colors": "background",
  "hover_popover_enabled": true,
  "format_on_save": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "auto_update": true,
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "empty_tab",
  "session": {
    "restore_unsaved_buffers": false,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
  "languages": {
    "Vue": {
      "language_servers": ["vize", "..."]
    }
  },
  "lsp": {
    "vize": {
      "initialization_options": {
        "lint": true
      }
    }
  }
}
